<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ pageTitle or site.title }}</title>
    <link rel="stylesheet" href="{{ stylesheetHref or '/styles/site.css' }}">
    <link rel="icon" href="{{ faviconSvgHref or '/favicon.svg' }}" type="image/svg+xml">
    <link rel="icon" href="{{ faviconPngHref or '/favicon.png' }}" type="image/png">
  </head>
  <body class="site-body">
    <main class="page-shell">
      {{ content | safe }}
    </main>
  </body>
</html>
